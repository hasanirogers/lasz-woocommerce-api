{
  "name": "lasz-woocommerce-api",
  "version": "1.0.0",
  "description": "A WordPress application",
  "main": "index.js",
  "scripts": {
    "build": "npm run rimraf && npm run wp-scripts:build",
    "dev": "concurrently npm:rimraf npm:wp-scripts:start",
    "rimraf": "rimraf lasz-woocommerce/build",
    "start": "npm run wp-env:start",
    "wp-env:log": "wp-env logs development",
    "wp-env:path": "wp-env install-path",
    "wp-env:plugins": "wp-env run cli wp plugin install updraftplus woocommerce",
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop all",
    "wp-env:reset": "wp-env reset",
    "wp-env:update": "wp-env start --update",
    "wp-scripts:build": "wp-scripts build --webpack-src-dir=lasz-woocommerce/blocks --output-path=lasz-woocommerce/build",
    "wp-scripts:format": "wp-scripts format",
    "wp-scripts:start": "wp-scripts start --webpack-src-dir=lasz-woocommerce/blocks --output-path=lasz-woocommerce/build"
  },
  "author": "Deific Arts LLC contact@deificarts.com",
  "license": "ISC",
  "dependencies": {
    "@wordpress/block-editor": "^15.16.0",
    "@wordpress/blocks": "^15.16.0",
    "@wordpress/element": "^6.43.0",
    "@wordpress/i18n": "^6.16.0",
    "kemet-ui": "^4.1.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wordpress/env": "^11.3.0",
    "@wordpress/scripts": "^31.8.0",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-sass": "^1.15.3",
    "sass": "^1.99.0",
    "typescript": "^6.0.2"
  }
}
